{
  "name": "wolfberg-cuas-3d",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Aegis-Edge: a realistic 3D counter-UAS simulation (three.js) driven by an explainable threat-call AI (Bedrock). AWS Global Government Hackathon, in-window build.",
  "scripts": {
