    "bench": "node --import tsx scripts/bench-gate.ts"
  },
  "dependencies": {
    "three": "^0.171.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/three": "^0.171.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0"
  }
}
